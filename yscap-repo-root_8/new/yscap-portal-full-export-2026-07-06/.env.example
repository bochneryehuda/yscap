# ---- core ----
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://user:pass@localhost:5432/yscapital
WEB_DIR=web

# ---- auth / crypto (generate long random values in prod) ----
JWT_SECRET=change-me-long-random
SSN_ENCRYPTION_KEY=change-me-long-random
ACCESS_TTL_SEC=3600
REFRESH_TTL_SEC=2592000

# ---- site intake ----
INTAKE_API_KEY=shared-secret-the-site-sends

# ---- notifications (email fan-out) ----
# EMAIL_PROVIDER: auto | none | graph | resend  (auto infers from the creds set).
# In-app notifications always work regardless.
EMAIL_PROVIDER=auto
NOTIFY_FROM=YS Capital Group <no-reply@yscapgroup.com>
# Base URL used for verify/reset links inside emails (the portal's public URL):
APP_URL=https://yscap.onrender.com
NOTIFY_ADMINS=admin1@yscapgroup.com,admin2@yscapgroup.com
# Resend (simplest to stand up) — the NOTIFY_FROM domain must be verified in Resend:
RESEND_API_KEY=
# Microsoft Graph (Outlook) — Azure app registration w/ Mail.Send (application):
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ---- document storage ----
STORAGE_PROVIDER=local
STORAGE_DIR=uploads

# ---- ClickUp (deferred) ----
CLICKUP_API_TOKEN=
