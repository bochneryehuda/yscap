    "key": "ignoreInvalidFields",
    "value": "true",
    "disabled": true
   }
  ],
  "desc": "Last modofied x days ",
  "body": "{\r\n    \"fields\": [\r\n        \"Loan.LoanRate\",\r\n        \"Loan.Address1\",\r\n        \"Loan.City\",\r\n        \"Loan.LastModified\",\r\n        \"Loan.LoanNumber\",\r\n        \"Loan.BorrowerName\"\r\n    ],\r\n    \"loanFolders\": [\r\n        \"My Pipeline\",\r\n        \"Prospects\"\r\n    ],\r\n    \"filter\": {\r\n        \"operator\": \"And\",\r\n        \"terms\": [\r\n            {\r\n                \"canonicalName\": \"Loan.CurrentMilestoneName\",\r\n                \"value\": [\r\n                    \"Started\"\r\n                ],\r\n                \"matchType\": \"MultiValue\"\r\n            },\r\n            {\r\n                \"canonicalName\": \"Loan.LastModified\",\r\n                \"value\": \"2019-05-09\",\r\n                \"matchType\": \"GreaterThanOrEquals\"\r\n            }\r\n        ]\r\n    },\r\n    \"orgType\": \"internal\",\r\n    \"loanOwnership\": \"AllLoans\",\r\n    \"sortOrder\": [\r\n        {\r\n            \"order\": \"Ascending\",\r\n            \"canonicalName\": \"Loan.LastModified\"\r\n        }\r\n    ]\r\n}"
 },
