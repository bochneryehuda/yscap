 {
  "folder": "Encompass Loan / Loan Pipeline / V3 Loan Pipeline",
  "name": "02 - Simple Query Pipeline",
  "method": "POST",
  "url": "{{API_SERVER}}/encompass/v3/loanPipeline?start=0&limit=1000",
  "query": [
   {
    "key": "start",
    "value": "0"
   },
   {
    "key": "limit",
    "value": "1000"
   }
  ],
  "desc": "Last modofied x days ",
  "body": "{\n    \"fields\": [\n        \"Loan.LoanFolder\",\n        \"Fields.4000\",\n        \"Loan.LoanNumber\",\n        \"Loan.LoanRate\",\n        \"Loan.LoanAmount\",\n        \"Loan.LastModified\",\n        \"Loan.BorrowerName\"\n    ],\n    \"sortOrder\": [\n        {\n            \"canonicalName\": \"Loan.LastModified\",\n            \"order\": \"Descending\"\n        }\n    ],\n    \"filter\": {\n        \"canonicalName\": \"Loan.LoanFolder\",\n        \"value\": \"(Trash)\",\n        \"matchType\": \"exact\",\n        \"precision\" : \"Day\"\n    },\n    \"orgType\": \"Internal\",\n    \"loanOwnership\": \"AllLoans\"\n}"
 },
 {
  "folder": "Encompass Loan / Loan Pipeline / V3 Loan Pipeline",
  "name": "03 - Complex Query Pipeline",
  "method": "POST",
  "url": "{{API_SERVER}}/encompass/v3/loanPipeline?limit=2000&include=LockInfo",
  "query": [
   {
    "key": "limit",
    "value": "2000"
   },
   {
    "key": "include",
    "value": "LockInfo"
   }
  ],
  "desc": "Last modofied x days ",
  "body": "{\n  \"filter\": {\n    \"operator\": \"and\",\n    \"terms\": [\n      {\n        \"canonicalName\": \"Loan.LoanFolder\",\n        \"value\": \"My Pipeline\",\n        \"matchType\": \"exact\",\n        \"include\": true\n      },\n      {\n        \"canonicalName\": \"Loan.LastModified\",\n        \"value\": \"02/25/2018\",\n        \"matchType\": \"greaterThanOrEquals\",\n        \"precision\": \"Day\"\n      },\n      {\n        \"operator\": \"and\",\n        \"terms\": [\n          {\n            \"canonicalName\": \"Loan.LoanRate\",\n            \"value\": \"10\",\n            \"matchType\": \"lessThanOrEquals\"\n          },\n          {\n            \"canonicalName\": \"Loan.LoanRate\",\n            \"value\": \"8\",\n            \"matchType\": \"greaterThanOrEquals\"\n          }\n      ]\n      }\n    ]\n  },\n  \"sortOrder\": [\n    {\n      \"canonicalName\": \"Loan.LastModified\",\n      \"order\": \"Descending\"\n    }\n  ]\n}"
 },
