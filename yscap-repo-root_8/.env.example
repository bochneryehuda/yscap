# ---- core ----
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://user:pass@localhost:5432/yscapital
WEB_DIR=web

# ---- auth / crypto (generate long random values in prod) ----
JWT_SECRET=change-me-long-random
SSN_ENCRYPTION_KEY=change-me-long-random
ACCESS_TTL_SEC=3600
REFRESH_TTL_SEC=2592000

# ---- site intake ----
INTAKE_API_KEY=shared-secret-the-site-sends

# ---- notifications (email fan-out) ----
# EMAIL_PROVIDER: none | graph | resend   (in-app notifications always work)
EMAIL_PROVIDER=none
NOTIFY_FROM=no-reply@yscapitalgroup.com
NOTIFY_ADMINS=admin1@yscapitalgroup.com,admin2@yscapitalgroup.com
# Microsoft Graph (Outlook) — Azure app registration w/ Mail.Send (application):
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Resend (simplest to stand up):
RESEND_API_KEY=

# ---- document storage ----
STORAGE_PROVIDER=local
STORAGE_DIR=uploads

# ---- ClickUp (deferred) ----
CLICKUP_API_TOKEN=
