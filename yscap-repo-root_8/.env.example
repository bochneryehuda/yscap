# ---- core ----
NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://user:pass@localhost:5432/yscapital
WEB_DIR=web

# ---- auth / crypto (generate long random values in prod) ----
JWT_SECRET=change-me-long-random
SSN_ENCRYPTION_KEY=change-me-long-random
ACCESS_TTL_SEC=3600
REFRESH_TTL_SEC=2592000

# ---- site intake ----
INTAKE_API_KEY=shared-secret-the-site-sends

# ---- notifications (email fan-out) ----
# EMAIL_PROVIDER: auto | none | graph | resend  (auto infers from the creds set).
# In-app notifications always work regardless.
EMAIL_PROVIDER=auto
NOTIFY_FROM=YS Capital Group <no-reply@yscapgroup.com>
# Base URL used for verify/reset links inside emails (the portal's public URL):
APP_URL=https://yscap.onrender.com
NOTIFY_ADMINS=admin1@yscapgroup.com,admin2@yscapgroup.com
# Resend (simplest to stand up) — the NOTIFY_FROM domain must be verified in Resend:
RESEND_API_KEY=
# Microsoft Graph (Outlook) — Azure app registration w/ Mail.Send (application):
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# ---- document storage ----
STORAGE_PROVIDER=local
STORAGE_DIR=uploads

# ---- document underwriting: OCR reader + AI analyzer (deferred until keys set) ----
# Azure AI Document Intelligence (reads scanned/blurry PDFs). Create a Document
# Intelligence resource in the Azure portal and paste its endpoint + key here. Default
# model 'prebuilt-read' is pure OCR; 2024-11-30 is the current GA API version:
AZURE_DOCINT_ENDPOINT=
AZURE_DOCINT_KEY=
AZURE_DOCINT_MODEL=prebuilt-read
AZURE_DOCINT_API_VERSION=2024-11-30
# Azure OpenAI (GPT-5) — the AI document analyzer. Create an Azure OpenAI resource,
# deploy a GPT-5 model, and paste its endpoint, key, and the deployment name here:
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ---- ClickUp (deferred) ----
CLICKUP_API_TOKEN=

# ---- SharePoint one-way sync (Pipeline Drive mirror) ----
# Mirrors every document into Pipeline Drive/<Officer>/<Borrower>/<Address>/
# YS portal syncing/<Condition>/ — write-only, never deletes (docs/SHAREPOINT-POLICY.md).
# Uses the MS_* Graph app credentials above. Master switch (0/1):
SHAREPOINT_BACKUP_ENABLED=0
# Pin the document-library drive id (from Graph /sites/{site}/drives). When set,
# host/path/name below are only a fallback:
SHAREPOINT_DRIVE_ID=
SHAREPOINT_SITE_HOST=yscapgroup.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/SharedData
SHAREPOINT_DRIVE_NAME=Documents
SHAREPOINT_PIPELINE_ROOT=Pipeline Drive
# Optional certificate auth (preferred over the secret when present; PEM with
# both PRIVATE KEY and CERTIFICATE blocks, or base64 of it in _B64):
MS_CLIENT_CERT_PEM=
MS_CLIENT_CERT_PEM_B64=
# Sweep interval in seconds (uploads also kick an immediate pass):
SHAREPOINT_BACKUP_POLL_SEC=300
